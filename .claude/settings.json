{
  "permissions": {
    "deny": [
      "Bash(rm -rf*)",
      "Bash(Remove-Item -Recurse -Force*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/check-secrets.ps1"
          }
        ]
      }
    ]
  }
}
